# Copy to .env and fill in real values. NEVER commit .env.
# The backend reads these as environment variables (see backend/src/main/resources/application.yml).

# --- Spotify OAuth app (https://developer.spotify.com/dashboard) ---
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Must EXACTLY match a Redirect URI registered in the Spotify dashboard.
# Dev (through the Vite proxy, browser-facing origin):
SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173/login/oauth2/code/spotify

# --- Frontend origin (post-login / error redirects) ---
FRONTEND_BASE_URI=http://127.0.0.1:5173

# --- Refresh-token encryption at rest ---
# password: any strong passphrase. salt: hex-encoded (e.g. `openssl rand -hex 8`).
TOKEN_ENCRYPTION_PASSWORD=replace-with-a-strong-passphrase
TOKEN_ENCRYPTION_SALT=5c0744940b5c369b

# --- Database (defaults match docker-compose.yml) ---
DB_URL=jdbc:postgresql://localhost:5433/spotystats
DB_USERNAME=spotystats
DB_PASSWORD=spotystats
