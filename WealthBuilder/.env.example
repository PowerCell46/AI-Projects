# WealthBuilder — Docker Compose deployment template.
# Use this when running the full stack via `docker compose up`.
# Running the backend directly (e.g. `mvn spring-boot:run`)? Use `backend/.env.example` instead —
# it uses the Spring property names (POSTGRE_SQL_*, APP_MODERATOR_*) directly; Compose maps the
# POSTGRES_* names below to those Spring names internally.
#
# Copy to `.env` (gitignored) at the repo root and fill in real values.

# --- Database (PostgreSQL container) ---
POSTGRES_DB=wealth_builder_db
POSTGRES_USER=wealthbuilder
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Schema management ---
# 'update' keeps data across restarts; switch to 'validate' once schema migrations are introduced.
DDL_AUTO=update

# --- JWT signing ---
# REQUIRED — the app refuses to start without both. Secret MUST be >= 32 chars for HS256;
# TTL is a duration string (e.g. 1h, 30m).
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
JWT_TTL=1h

# --- Moderator seeding ---
# A single MODERATOR is seeded at startup only if none exists yet.
APP_MODERATOR_USERNAME=admin
APP_MODERATOR_PASSWORD=change-me-strong-admin-password

# --- Frontend origins (CORS) ---
# Behind the nginx edge proxy the SPA and API share the same origin (https://localhost), so
# only that one origin needs to be listed here. For a split-host setup list each origin.
FRONTEND_BASE_URIS=https://localhost
