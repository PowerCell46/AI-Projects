# Copy to .env and fill in real values: cp .env.example .env
# .env is gitignored — never commit real secrets.

# --- Database ---
POSTGRES_DB=wealth_builder_db
POSTGRES_USER=wealthbuilder
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Hibernate schema management ---
# update = keep data across restarts | create = wipe & recreate every boot | validate
DDL_AUTO=update

# --- JWT (HS256) ---
# MUST be at least 32 characters (256 bits). Generate one, e.g.:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars-long
# Token lifetime as a Spring Duration: 1h, 30m, 24h, etc.
JWT_TTL=1h

# --- Seeded moderator (created at startup if absent; blank password disables seeding) ---
APP_MODERATOR_USERNAME=admin
APP_MODERATOR_PASSWORD=change-me-strong-admin-password

# --- CORS allowed origin(s) ---
# The public HTTPS origin the SPA is served from. Comma-separated for multiple.
FRONTEND_BASE_URIS=https://localhost
