# WealthBuilder backend — environment template.
# Copy to `.env` (gitignored) and fill in real values, or export these in your shell.
# Every var has a fallback in application.properties; the notes below say what each default does.

# --- Database (PostgreSQL) ---
# URL has a working localhost default; username/password default to a placeholder that
# WILL fail to connect — set these to your real Postgres credentials.
POSTGRE_SQL_URL=jdbc:postgresql://127.0.0.1:5432/wealth_builder_db
POSTGRE_SQL_USERNAME=postgres
POSTGRE_SQL_PASSWORD=change-me

# --- JWT signing ---
# Secret MUST be >= 256 bits (32+ chars) for HS256. The app refuses to start with the
# built-in dev secret under a non-dev profile (see JwtSecretValidator), so set a private
# value for any real deployment. TTL is an ISO-8601 duration (PT24H = 24 hours).
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_TTL=PT24H

# --- Frontend origin (CORS) ---
# The browser-facing SPA origin allowed to call the API. Defaults to the Vite dev server.
FRONTEND_BASE_URI=http://localhost:5173

# --- Moderator seeding ---
# A single MODERATOR is seeded at startup only if none exists yet. Leave the password
# BLANK to skip seeding entirely (e.g. in CI). Set both to provision the first moderator.
APP_MOD_USERNAME=moderator
APP_MOD_PASSWORD=
