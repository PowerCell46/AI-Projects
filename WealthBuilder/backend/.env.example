# WealthBuilder backend — local development template.
# Use this when running the backend directly (e.g. `mvn spring-boot:run`) WITHOUT Docker Compose.
# Docker Compose users: use the root `.env.example` instead — Compose maps its vars to the ones
# Spring expects, so the names here (POSTGRE_SQL_*, APP_MODERATOR_*) differ from the root file.
#
# Copy to `.env` (gitignored) and fill in real values, or export these in your shell.
# JWT_SECRET, JWT_TTL, and FRONTEND_BASE_URIS have NO fallback and are mandatory.

# --- Database (PostgreSQL) ---
# URL has a working localhost default; username/password default to a placeholder that
# WILL fail to connect — set these to your real Postgres credentials.
POSTGRE_SQL_URL=jdbc:postgresql://127.0.0.1:5432/wealth_builder_db
POSTGRE_SQL_USERNAME=postgres
POSTGRE_SQL_PASSWORD=change-me

# --- JWT signing ---
# REQUIRED — these have NO fallback in application.properties, so the app refuses to start
# unless both are set. Secret MUST be >= 256 bits (32+ chars) for HS256; TTL is a
# duration string (e.g. 1h, 30m, PT2H — Spring's relaxed binding accepts both forms).
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars
JWT_TTL=1h

# --- Frontend origins (CORS) ---
# REQUIRED — no fallback in application.properties, so the app refuses to start unless set.
# For local dev the Vite server can run on any port, so [*] covers all of them. In production
# set this to the exact deployed origin only, e.g. https://app.example.com
FRONTEND_BASE_URIS=http://localhost:[*],http://127.0.0.1:[*]

# --- Auth cookie (httpOnly JWT) ---
# The JWT is delivered in an httpOnly cookie, not the response body. All optional (sensible
# dev defaults shown). Set AUTH_COOKIE_SECURE=true on any https deployment. If the SPA and API
# are served from different sites in production, use AUTH_COOKIE_SAME_SITE=None with Secure=true;
# for a same-site setup (e.g. both behind one nginx) keep Lax.
AUTH_COOKIE_NAME=wb_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax

# --- Moderator seeding ---
# A single MODERATOR is seeded at startup only if none exists yet. Leave the password
# BLANK to skip seeding entirely (e.g. in CI). Set both to provision the first moderator.
APP_MODERATOR_USERNAME=moderator
APP_MODERATOR_PASSWORD=
