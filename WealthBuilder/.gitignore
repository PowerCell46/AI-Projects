# Secrets / environment
.env
*.env.local

# TLS certificates / keys (never commit) — keep the dir via .gitkeep
nginx/certs/*
!nginx/certs/.gitkeep

# OS / editor
.DS_Store
Thumbs.db
.idea/
*.iml
.vscode/

# Node (frontend)
node_modules/
dist/

# Java (backend) — backend/.gitignore also applies
target/
